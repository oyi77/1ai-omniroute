# 1ai-omniroute .gitignore

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
*.log

# Backup files
*.bak
*.backup
*~

# Temporary files
tmp/
temp/
.tmp/

# Secrets (should never be committed)
*.key
*.pem
*.secret
*.env
.env.*
!.env.example

# Test artifacts
coverage/
.nyc_output/
htmlcov/
.coverage
.coverage.*

# Build artifacts
dist/
build/
*.tgz
*.tar.gz

# IDE specific
.idea/
.vscode/
*.swp
*.swo
*~

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# OmniRoute specific
*.sqlite
*.db
update.log
