# 1ai-omniroute Environment Configuration
# ========================================
# Copy this file to .env and fill in your actual secrets.
# NEVER commit .env files to version control!

# Antigravity OAuth Configuration
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
ANTIGRAVITY_OAUTH_CLIENT_SECRET=YOUR_ANTIGRAVITY_OAUTH_CLIENT_SECRET_HERE

# OmniRoute API Configuration
OMNIROUTE_API_KEY=YOUR_OMNIROUTE_API_KEY_HERE
OMNIROUTE_PORT=20128

# Update Configuration
# Set to "true" to enable automatic updates
AUTO_UPDATE_ENABLED=false
UPDATE_LOG_FILE=/home/openclaw/.omniroute/update.log
